## See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# === FRONTEND: Node / Next.js / Vercel ===
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions
/.next/
/out/
/build
.vercel

# === TESTING ===
/coverage

# === DEBUG / LOGS ===
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# === MISC ===
.DS_Store
*.pem
*.zip

# === TYPESCRIPT ===
*.tsbuildinfo
next-env.d.ts

# === ENV FILES ===
.env*
frontend/.env.local
backend/.env

# === BACKEND: Python ===
backend/.venv/
__pycache__/
*.py[cod]